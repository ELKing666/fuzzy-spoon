# Supabase (public anon / publishable key - safe for client)
# Copy this file to .env and fill real values, or set in your hosting dashboard (Railway)
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_URL="https://your-project.supabase.co"

# Vite-prefixed versions (used by client code)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Add any other server-only secrets here (never VITE_ prefix for server-only)
# WHATSAPP_PHONE=...
